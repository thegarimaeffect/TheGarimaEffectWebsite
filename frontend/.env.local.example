# Local development with `supabase start` uses these well-known defaults.
# When deploying to Vercel, replace with your real Supabase Cloud project values.

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from `npx supabase status`>
SUPABASE_SERVICE_ROLE_KEY=<from `npx supabase status` — SERVER ONLY>
NEXT_PUBLIC_SITE_URL=http://localhost:3000
